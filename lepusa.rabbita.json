  "rootHtml": "<link href=\"/assets/moongate.css\" rel=\"stylesheet\"><div data-moongate-api-base=\"http://127.0.0.1:15721\" data-moongate-framework-apps=\"[{&quot;id&quot;:&quot;claude&quot;,&quot;label&quot;:&quot;Claude Code&quot;,&quot;mode&quot;:&quot;single&quot;},{&quot;id&quot;:&quot;claude-desktop&quot;,&quot;label&quot;:&quot;Claude Desktop&quot;,&quot;mode&quot;:&quot;single&quot;,&quot;desktop&quot;:true},{&quot;id&quot;:&quot;codex&quot;,&quot;label&quot;:&quot;Codex&quot;,&quot;mode&quot;:&quot;single&quot;},{&quot;id&quot;:&quot;gemini&quot;,&quot;label&quot;:&quot;Gemini&quot;,&quot;mode&quot;:&quot;single&quot;},{&quot;id&quot;:&quot;opencode&quot;,&quot;label&quot;:&quot;OpenCode&quot;,&quot;mode&quot;:&quot;additive&quot;},{&quot;id&quot;:&quot;openclaw&quot;,&quot;label&quot;:&quot;OpenClaw&quot;,&quot;mode&quot;:&quot;additive&quot;},{&quot;id&quot;:&quot;hermes&quot;,&quot;label&quot;:&quot;Hermes&quot;,&quot;mode&quot;:&quot;additive&quot;}]\" data-moongate-endpoints=\"{&quot;health&quot;:&quot;/health&quot;,&quot;status&quot;:&quot;/status&quot;,&quot;proxy&quot;:&quot;/proxy/status&quot;,&quot;proxyStart&quot;:&quot;/proxy/start&quot;,&quot;proxyStop&quot;:&quot;/proxy/stop&quot;,&quot;syncLive&quot;:&quot;/proxy/sync-current-providers-live&quot;,&quot;providerCreate&quot;:&quot;/providers&quot;,&quot;providerCurrent&quot;:&quot;/providers/current&quot;,&quot;providerUpdate&quot;:&quot;/providers/update&quot;,&quot;providerDelete&quot;:&quot;/providers&quot;,&quot;providerSwitch&quot;:&quot;/providers/switch&quot;,&quot;providerImportLive&quot;:&quot;/providers/import-live&quot;,&quot;providerPresets&quot;:&quot;/providers/presets&quot;,&quot;providerStreamCheck&quot;:&quot;/proxy/stream-check/provider&quot;,&quot;usageSummary&quot;:&quot;/usage/summary&quot;,&quot;usageByApp&quot;:&quot;/usage/summary/by-app&quot;,&quot;usageTrends&quot;:&quot;/usage/trends&quot;,&quot;providerStats&quot;:&quot;/usage/provider-stats&quot;,&quot;modelStats&quot;:&quot;/usage/model-stats&quot;,&quot;usageLogs&quot;:&quot;/usage/logs&quot;,&quot;logs&quot;:&quot;/usage/logs?limit=8&quot;,&quot;requestDetail&quot;:&quot;/usage/request-detail&quot;,&quot;authStatus&quot;:&quot;/auth/status&quot;,&quot;configStatus&quot;:&quot;/config/status&quot;,&quot;configFolderOpen&quot;:&quot;/config/folder/open&quot;,&quot;claudeDesktopStatus&quot;:&quot;/providers/claude-desktop/status&quot;,&quot;claudeDesktopImport&quot;:&quot;/providers/claude-desktop/import&quot;,&quot;mcpServers&quot;:&quot;/mcp/servers&quot;,&quot;mcpImportApps&quot;:&quot;/mcp/import-apps&quot;,&quot;settings&quot;:&quot;/settings&quot;,&quot;portableMode&quot;:&quot;/runtime/portable-mode&quot;,&quot;toolsVersions&quot;:&quot;/tools/versions&quot;,&quot;proxyRunning&quot;:&quot;/proxy/running&quot;,&quot;takeoverStatus&quot;:&quot;/proxy/takeover-status&quot;,&quot;pluginClaudeStatus&quot;:&quot;/plugin/claude/status&quot;,&quot;pluginClaudeApplied&quot;:&quot;/plugin/claude/applied&quot;,&quot;circuitConfig&quot;:&quot;/proxy/circuit-breaker-config&quot;,&quot;circuitStats&quot;:&quot;/proxy/circuit-breaker-stats&quot;,&quot;resetCircuit&quot;:&quot;/proxy/reset-circuit-breaker&quot;,&quot;failoverQueue&quot;:&quot;/proxy/failover-queue&quot;,&quot;availableFailover&quot;:&quot;/proxy/available-failover-providers&quot;,&quot;autoFailover&quot;:&quot;/proxy/auto-failover-enabled&quot;,&quot;providerLimits&quot;:&quot;/usage/provider-limits&quot;,&quot;streamCheckAll&quot;:&quot;/proxy/stream-check/all&quot;,&quot;streamCheckConfig&quot;:&quot;/proxy/stream-check/config&quot;,&quot;suiteManifest&quot;:&quot;/suite/manifest&quot;,&quot;suiteStatus&quot;:&quot;/suite/status&quot;,&quot;suiteDrift&quot;:&quot;/suite/drift&quot;,&quot;suiteWriteStatus&quot;:&quot;/suite/status/write&quot;,&quot;suiteMoonclawProviders&quot;:&quot;/suite/moonclaw-providers&quot;,&quot;suiteWriteMoonclawProviders&quot;:&quot;/suite/moonclaw-providers/write&quot;}\" data-moongate-readiness-cards=\"[{&quot;id&quot;:&quot;gateway&quot;,&quot;label&quot;:&quot;MoonGate&quot;,&quot;ready&quot;:&quot;Ready&quot;,&quot;waiting&quot;:&quot;Unavailable&quot;,&quot;target&quot;:&quot;#overview&quot;},{&quot;id&quot;:&quot;proxy&quot;,&quot;label&quot;:&quot;AI routing&quot;,&quot;ready&quot;:&quot;Running&quot;,&quot;waiting&quot;:&quot;Needs start&quot;,&quot;target&quot;:&quot;#overview&quot;},{&quot;id&quot;:&quot;providers&quot;,&quot;label&quot;:&quot;Providers&quot;,&quot;ready&quot;:&quot;Configured&quot;,&quot;waiting&quot;:&quot;Add provider&quot;,&quot;target&quot;:&quot;#providers&quot;},{&quot;id&quot;:&quot;usage&quot;,&quot;label&quot;:&quot;Usage&quot;,&quot;ready&quot;:&quot;Tracking&quot;,&quot;waiting&quot;:&quot;No traffic yet&quot;,&quot;target&quot;:&quot;#usage&quot;},{&quot;id&quot;:&quot;requests&quot;,&quot;label&quot;:&quot;Requests&quot;,&quot;ready&quot;:&quot;Recent activity&quot;,&quot;waiting&quot;:&quot;No requests yet&quot;,&quot;target&quot;:&quot;#requests&quot;}]\" data-moongate-sections=\"[{&quot;id&quot;:&quot;overview&quot;,&quot;label&quot;:&quot;Overview&quot;,&quot;target&quot;:&quot;#overview&quot;},{&quot;id&quot;:&quot;connect&quot;,&quot;label&quot;:&quot;Connect&quot;,&quot;target&quot;:&quot;#connect&quot;},{&quot;id&quot;:&quot;setup&quot;,&quot;label&quot;:&quot;Setup&quot;,&quot;target&quot;:&quot;#setup&quot;},{&quot;id&quot;:&quot;routing&quot;,&quot;label&quot;:&quot;Routing&quot;,&quot;target&quot;:&quot;#routing&quot;},{&quot;id&quot;:&quot;providers&quot;,&quot;label&quot;:&quot;Providers&quot;,&quot;target&quot;:&quot;#providers&quot;},{&quot;id&quot;:&quot;requests&quot;,&quot;label&quot;:&quot;Requests&quot;,&quot;target&quot;:&quot;#requests&quot;},{&quot;id&quot;:&quot;usage&quot;,&quot;label&quot;:&quot;Usage&quot;,&quot;target&quot;:&quot;#usage&quot;},{&quot;id&quot;:&quot;suite&quot;,&quot;label&quot;:&quot;Suite&quot;,&quot;target&quot;:&quot;#suite&quot;},{&quot;id&quot;:&quot;guide&quot;,&quot;label&quot;:&quot;Guide&quot;,&quot;target&quot;:&quot;#guide&quot;}]\" class=\"shell\"><aside aria-label=\"MoonGate navigation\" class=\"sidebar\"><div class=\"brand\"><img aria-hidden=\"true\" src=\"/assets/moongate.svg\" alt=\"\" width=\"32\" height=\"32\" class=\"brand-mark\"><div class=\"brand-copy\"><strong>MoonGate</strong><span>Local AI router</span></div></div><nav class=\"nav\" id=\"nav\"><span class=\"nav-group-label\">Start</span><a data-page=\"overview\" href=\"#overview\" target=\"_self\" class=\"nav-item active\"><span aria-hidden=\"true\" class=\"nav-icon\">OV</span><span class=\"nav-label\">Overview</span></a><a data-page=\"connect\" href=\"#connect\" target=\"_self\" class=\"nav-item\"><span aria-hidden=\"true\" class=\"nav-icon\">CN</span><span class=\"nav-label\">Connect</span></a><a data-page=\"setup\" href=\"#setup\" target=\"_self\" class=\"nav-item\"><span aria-hidden=\"true\" class=\"nav-icon\">ST</span><span class=\"nav-label\">Setup</span></a><span class=\"nav-group-label\">Configure</span><a data-page=\"routing\" href=\"#routing\" target=\"_self\" class=\"nav-item\"><span aria-hidden=\"true\" class=\"nav-icon\">RT</span><span class=\"nav-label\">Routing</span></a><a data-page=\"providers\" href=\"#providers\" target=\"_self\" class=\"nav-item\"><span aria-hidden=\"true\" class=\"nav-icon\">PR</span><span class=\"nav-label\">Providers</span></a><a data-page=\"requests\" href=\"#requests\" target=\"_self\" class=\"nav-item\"><span aria-hidden=\"true\" class=\"nav-icon\">RQ</span><span class=\"nav-label\">Requests</span></a><span class=\"nav-group-label\">Review</span><a data-page=\"usage\" href=\"#usage\" target=\"_self\" class=\"nav-item\"><span aria-hidden=\"true\" class=\"nav-icon\">US</span><span class=\"nav-label\">Usage</span></a><a data-page=\"suite\" href=\"#suite\" target=\"_self\" class=\"nav-item\"><span aria-hidden=\"true\" class=\"nav-icon\">SU</span><span class=\"nav-label\">Suite</span></a><a data-page=\"guide\" href=\"#guide\" target=\"_self\" class=\"nav-item\"><span aria-hidden=\"true\" class=\"nav-icon\">?</span><span class=\"nav-label\">Guide</span></a></nav><div class=\"sidebar-footer\"><div class=\"sidebar-status\"><span class=\"dot warn\" id=\"sidebar-gateway-dot\"></span><div><strong id=\"sidebar-gateway-state\">Gateway connecting</strong><span id=\"ui-updated\">Waiting for data</span></div></div></div></aside><main class=\"main\"><header class=\"topbar\"><div class=\"topbar-title\"><h1 id=\"page-title\">Overview</h1><p id=\"page-subtitle\">See whether MoonGate is ready, which provider is in use, and what it has handled.</p></div><div class=\"topbar-actions\"><span class=\"updated-chip\" id=\"topbar-updated\">Updating…</span><span class=\"env-chip\"><span class=\"dot warn\" id=\"gateway-dot\"></span><code id=\"gateway-endpoint\">Connecting…</code></span><button type=\"button\" class=\"button-secondary\" id=\"refresh\">Refresh</button></div></header><section data-page-view=\"overview\" data-page-title=\"Overview\" data-page-subtitle=\"See whether MoonGate is ready, which provider is in use, and what it has handled.\" class=\"page active\" id=\"page-overview\"><section class=\"hero\" id=\"overview\"><div class=\"hero-state\"><span class=\"dot warn\" id=\"gateway-hero-dot\"></span><div class=\"hero-text\"><strong>MoonGate <span id=\"gateway-state\">Loading</span></strong><small id=\"gateway-detail\">Connecting to the local API</small></div></div><div class=\"hero-stats\"><div class=\"hero-stat\"><span>AI routing</span><strong id=\"proxy-state\">Loading</strong><small id=\"proxy-detail\">Checking route state</small></div><div class=\"hero-stat\"><span>Settings access</span><strong>This Mac only</strong><small>Other devices cannot change settings</small></div></div><div class=\"hero-actions\"><button type=\"button\" class=\"danger-ghost\" id=\"proxy-stop\">Stop Routing</button><button type=\"button\" id=\"proxy-start\">Start Routing</button><button data-goto=\"usage\" type=\"button\" class=\"button-secondary\">View Usage</button></div></section><section class=\"status-grid\"><article class=\"metric-card\"><span>Requests</span><strong id=\"request-total\">-</strong><small id=\"request-total-detail\">Across all apps</small></article><article class=\"metric-card\"><span>Spend</span><strong id=\"cost-total\">-</strong><small id=\"cost-detail\">Estimated total</small></article><article class=\"metric-card\"><span>Supported apps</span><strong id=\"framework-total\">-</strong><small id=\"framework-detail\">AI app types</small></article><article class=\"metric-card\"><span>Local port</span><strong id=\"gateway-port\">-</strong><small id=\"gateway-port-detail\">Used by apps on this Mac</small></article></section><div class=\"overview-grid\"><section aria-label=\"MoonGate readiness\" class=\"readiness-panel panel\" id=\"readiness\"><div class=\"panel-head\"><div><p class=\"eyebrow\">Readiness</p><h2>Ready to use</h2></div><span class=\"panel-hint\">Live checks</span></div><div class=\"readiness-cards\" id=\"readiness-cards\"></div></section><article class=\"panel overview-models\"><div class=\"panel-head\"><div><p class=\"eyebrow\">Traffic</p><h2>Top Models</h2></div></div><div class=\"stack\" id=\"model-usage\"></div></article></div><section class=\"quick-connect\"><div class=\"section-title\"><h2>Connect quickly</h2><span>Addresses most apps ask for</span><a data-goto=\"connect\" href=\"#connect\" target=\"_self\">View all</a></div><div class=\"copy-row\"><div class=\"copy-who\"><strong>OpenAI</strong><small>Chat completions</small></div><code data-url-path=\"/v1/chat/completions\">/v1/chat/completions</code><button data-copy-path=\"/v1/chat/completions\" type=\"button\" class=\"button-secondary copy-button\">Copy</button></div><div class=\"copy-row\"><div class=\"copy-who\"><strong>Anthropic</strong><small>Messages</small></div><code data-url-path=\"/v1/messages\">/v1/messages</code><button data-copy-path=\"/v1/messages\" type=\"button\" class=\"button-secondary copy-button\">Copy</button></div><div class=\"copy-row\"><div class=\"copy-who\"><strong>Monitoring data (advanced)</strong><small>For Prometheus dashboards; this is not an app screen</small></div><code data-url-path=\"/metrics\">/metrics</code><button data-copy-path=\"/metrics\" type=\"button\" class=\"button-secondary copy-button\">Copy</button></div></section></section><section data-page-view=\"connect\" data-page-title=\"Connect\" data-page-subtitle=\"Copy the API address or command-line settings requested by another AI app.\" class=\"page\" id=\"page-connect\"><section class=\"connection-board\" id=\"connection-board\"><div class=\"page-intro\"><div><h2>Connect an AI app</h2><p>Use this page when an app asks for a Base URL, API address, or environment variables. MoonGate supports several API formats on one local address.</p></div><span class=\"updated-chip\" id=\"connection-copy-status\">Ready to copy</span></div><div class=\"section-title\"><h3>API addresses</h3><span>Choose the format named by your app</span></div><div class=\"connection-grid\"><article class=\"connection-card\"><div><strong>OpenAI Chat</strong><small>OpenAI-compatible clients</small></div><div class=\"endpoint-url\"><code data-url-path=\"/v1/chat/completions\">/v1/chat/completions</code><button data-copy-path=\"/v1/chat/completions\" type=\"button\" class=\"button-secondary copy-button\">Copy</button></div></article><article class=\"connection-card\"><div><strong>OpenAI Responses</strong><small>Codex-style responses clients</small></div><div class=\"endpoint-url\"><code data-url-path=\"/v1/responses\">/v1/responses</code><button data-copy-path=\"/v1/responses\" type=\"button\" class=\"button-secondary copy-button\">Copy</button></div></article><article class=\"connection-card\"><div><strong>Anthropic Messages</strong><small>Claude-compatible clients</small></div><div class=\"endpoint-url\"><code data-url-path=\"/v1/messages\">/v1/messages</code><button data-copy-path=\"/v1/messages\" type=\"button\" class=\"button-secondary copy-button\">Copy</button></div></article><article class=\"connection-card\"><div><strong>Claude Desktop</strong><small>Desktop gateway route</small></div><div class=\"endpoint-url\"><code data-url-path=\"/claude-desktop/v1/messages\">/claude-desktop/v1/messages</code><button data-copy-path=\"/claude-desktop/v1/messages\" type=\"button\" class=\"button-secondary copy-button\">Copy</button></div></article><article class=\"connection-card\"><div><strong>OpenClaw</strong><small>OpenClaw chat route</small></div><div class=\"endpoint-url\"><code data-url-path=\"/openclaw/v1/chat/completions\">/openclaw/v1/chat/completions</code><button data-copy-path=\"/openclaw/v1/chat/completions\" type=\"button\" class=\"button-secondary copy-button\">Copy</button></div></article><article class=\"connection-card\"><div><strong>Monitoring data (advanced)</strong><small>For Prometheus dashboards; copy only</small></div><div class=\"endpoint-url\"><code data-url-path=\"/metrics\">/metrics</code><button data-copy-path=\"/metrics\" type=\"button\" class=\"button-secondary copy-button\">Copy</button></div></article></div><div class=\"section-title\"><h3>Command-line setup</h3><span>Copy only when a terminal app asks for environment variables</span></div><div class=\"snippet-list\"><article class=\"copy-row snippet-row\"><div class=\"copy-who\"><strong>OpenAI env</strong><small>OpenAI-compatible clients</small></div><code data-snippet=\"openai-env\"></code><button data-copy-snippet=\"openai-env\" type=\"button\" class=\"button-secondary copy-button\">Copy</button></article><article class=\"copy-row snippet-row\"><div class=\"copy-who\"><strong>Anthropic env</strong><small>Claude-compatible clients</small></div><code data-snippet=\"anthropic-env\"></code><button data-copy-snippet=\"anthropic-env\" type=\"button\" class=\"button-secondary copy-button\">Copy</button></article><article class=\"copy-row snippet-row\"><div class=\"copy-who\"><strong>OpenClaw env</strong><small>OpenClaw clients</small></div><code data-snippet=\"openclaw-env\"></code><button data-copy-snippet=\"openclaw-env\" type=\"button\" class=\"button-secondary copy-button\">Copy</button></article><article class=\"copy-row snippet-row\"><div class=\"copy-who\"><strong>Monitoring URL (advanced)</strong><small>For Prometheus dashboards</small></div><code data-snippet=\"metrics-url\"></code><button data-copy-snippet=\"metrics-url\" type=\"button\" class=\"button-secondary copy-button\">Copy</button></article></div></section></section><section data-page-view=\"setup\" data-page-title=\"Setup\" data-page-subtitle=\"Check sign-ins and whether installed AI apps are configured to use MoonGate.\" class=\"page\" id=\"page-setup\"><article class=\"panel wide\" id=\"setup\"><div class=\"panel-head\"><div><p class=\"eyebrow\">Setup</p><h2>App readiness</h2></div><div class=\"inline-actions\"><button type=\"button\" class=\"button-secondary\" id=\"setup-refresh\">Check Again</button><button type=\"button\" class=\"button-secondary\" id=\"setup-import-mcp\">Detect App Extensions</button></div></div><div class=\"panel-description\"><strong>What are command-line apps and extensions?</strong><p>MoonGate detects installed apps such as Codex, Claude, Gemini, and OpenCode so it knows which apps it can configure. Extensions (including MCP) let an AI app use capabilities such as files or services; you only need them when an app asks for one.</p></div><div class=\"setup-grid\"><div class=\"setup-card\"><div class=\"setup-card-head\"><strong>Signed-in accounts</strong><span class=\"state warn\" id=\"setup-auth-state\">Loading</span></div><div class=\"setup-list\" id=\"setup-auth-rows\"></div></div><div class=\"setup-card\"><div class=\"setup-card-head\"><strong>MoonGate &amp; installed apps</strong><span class=\"state warn\" id=\"setup-runtime-state\">Loading</span></div><div class=\"setup-list\" id=\"setup-runtime-rows\"></div></div><div class=\"setup-card\"><div class=\"setup-card-head\"><strong>Claude Desktop</strong><span class=\"state warn\" id=\"setup-desktop-state\">Loading</span></div><div class=\"setup-list\" id=\"setup-desktop-rows\"></div><div class=\"inline-actions\"><button type=\"button\" id=\"setup-import-claude-desktop\">Use Claude Desktop Setup</button></div></div><div class=\"setup-card\"><div class=\"setup-card-head\"><strong>AI app extensions</strong><span class=\"state warn\" id=\"setup-mcp-state\">Loading</span></div><div class=\"setup-list\" id=\"setup-mcp-rows\"></div></div></div><div class=\"table-wrap setup-table-wrap\"><table><thead><tr><th>AI app</th><th>Settings found</th><th>Routed through MoonGate</th><th>Action</th></tr></thead><tbody id=\"setup-config-rows\"></tbody></table></div></article></section><section data-page-view=\"routing\" data-page-title=\"Routing\" data-page-subtitle=\"Choose which provider each AI app uses; backups are available under Advanced.\" class=\"page\" id=\"page-routing\"><article class=\"panel wide\" id=\"frameworks\"><div class=\"panel-head\"><div><p class=\"eyebrow\">AI apps</p><h2>Provider choice</h2></div><button type=\"button\" class=\"button-secondary\" id=\"sync-live\">Save Current Routes</button></div><p class=\"panel-description\">Choose the provider each AI app should use. “One active” means the app uses one provider at a time; “Multiple active” means it can keep several provider entries.</p><div class=\"table-wrap\"><table><thead><tr><th>AI app</th><th>Provider mode</th><th>In use</th><th>Available</th><th>Actions</th></tr></thead><tbody id=\"framework-rows\"></tbody></table></div></article><article class=\"panel wide\" id=\"resilience\"><div class=\"panel-head\"><div><p class=\"eyebrow\">Advanced</p><h2>Backup &amp; failure handling</h2></div><div class=\"filter-row\"><select aria-label=\"Resilience framework\" id=\"resilience-app\"></select><select aria-label=\"Resilience provider\" id=\"resilience-provider\"></select><button type=\"button\" class=\"button-secondary\" id=\"resilience-refresh\">Refresh</button></div></div><p class=\"panel-description\">Optional controls for using a backup provider and pausing a provider that repeatedly fails. Leave these at their defaults unless you need automatic recovery.</p><details class=\"advanced-disclosure\"><summary>Show advanced failure controls</summary><div class=\"usage-metrics\"><div><span>Automatic backup</span><strong id=\"resilience-auto-state\">-</strong></div><div><span>Selected provider</span><strong id=\"resilience-circuit-state\">-</strong></div><div><span>Backup count</span><strong id=\"resilience-queue-count\">-</strong></div><div><span>Provider limits</span><strong id=\"resilience-limit-state\">-</strong></div></div><div class=\"resilience-grid\"><div class=\"setup-card\"><div class=\"setup-card-head\"><strong>Pause a failing provider</strong><span class=\"state warn\" id=\"resilience-circuit-status\">Loading</span></div><p class=\"card-help\">Pause after repeated failures, then resume after enough successful checks. Failure rate uses a value from 0 to 1.</p><form class=\"compact-form\" id=\"circuit-form\"><label><span>Failures before pause</span><input inputmode=\"numeric\" type=\"text\" autocomplete=\"off\" placeholder=\"\" id=\"circuit-failure-threshold\"></label><label><span>Successes before recovery</span><input inputmode=\"numeric\" type=\"text\" autocomplete=\"off\" placeholder=\"\" id=\"circuit-success-threshold\"></label><label><span>Pause duration (seconds)</span><input inputmode=\"numeric\" type=\"text\" autocomplete=\"off\" placeholder=\"\" id=\"circuit-timeout-seconds\"></label><label><span>Failure rate (0 to 1)</span><input inputmode=\"decimal\" type=\"text\" autocomplete=\"off\" placeholder=\"\" id=\"circuit-error-rate-threshold\"></label><label><span>Minimum requests</span><input inputmode=\"numeric\" type=\"text\" autocomplete=\"off\" placeholder=\"\" id=\"circuit-min-requests\"></label><div class=\"inline-actions\"><button type=\"submit\">Save Failure Rules</button><button type=\"button\" class=\"button-secondary\" id=\"resilience-reset-circuit\">Reset Selected</button></div></form></div><div class=\"setup-card\"><div class=\"setup-card-head\"><strong>Streaming connection test</strong><span class=\"state warn\" id=\"resilience-stream-status\">Loading</span></div><p class=\"card-help\">Checks that a provider can return an answer piece by piece. These settings affect only the test.</p><form class=\"compact-form\" id=\"stream-form\"><label><span>Test timeout (seconds)</span><input inputmode=\"numeric\" type=\"text\" autocomplete=\"off\" placeholder=\"\" id=\"stream-timeout-secs\"></label><label><span>Max Retries</span><input inputmode=\"numeric\" type=\"text\" autocomplete=\"off\" placeholder=\"\" id=\"stream-max-retries\"></label><label><span>Slow after (milliseconds)</span><input inputmode=\"numeric\" type=\"text\" autocomplete=\"off\" placeholder=\"\" id=\"stream-degraded-threshold-ms\"></label><label><span>Codex Model</span><input type=\"text\" autocomplete=\"off\" placeholder=\"\" id=\"stream-codex-model\"></label><label><span>Claude Model</span><input type=\"text\" autocomplete=\"off\" placeholder=\"\" id=\"stream-claude-model\"></label><label><span>Gemini Model</span><input type=\"text\" autocomplete=\"off\" placeholder=\"\" id=\"stream-gemini-model\"></label><label class=\"span-2\"><span>Test prompt</span><input type=\"text\" autocomplete=\"off\" placeholder=\"\" id=\"stream-test-prompt\"></label><div class=\"inline-actions span-2\"><button type=\"submit\">Save Test Settings</button><button type=\"button\" class=\"button-secondary\" id=\"resilience-stream-check\">Run Connection Test</button></div></form></div></div><div class=\"resilience-grid\"><div class=\"setup-card\"><div class=\"setup-card-head\"><strong>Backup order</strong><button type=\"button\" class=\"button-secondary\" id=\"resilience-toggle-auto\">Turn Automatic Backup On</button></div><div class=\"stack\" id=\"failover-queue\"></div></div><div class=\"setup-card\"><div class=\"setup-card-head\"><strong>Available backups</strong><button type=\"button\" class=\"button-secondary\" id=\"resilience-add-selected\">Add Selected</button></div><div class=\"stack\" id=\"available-failover\"></div></div></div><div class=\"log-list\" id=\"stream-check-results\"></div></details></article></section><section data-page-view=\"providers\" data-page-title=\"Providers\" data-page-subtitle=\"Add providers, test their real connection, and select or stop a routing profile.\" class=\"page\" id=\"page-providers\"><div class=\"master-detail provider-master-detail\"><article class=\"panel wide\" id=\"provider-health\"><div class=\"panel-head\"><div><p class=\"eyebrow\">Routing</p><h2>Provider Routes</h2></div><span class=\"pill\" id=\"provider-count\">0 providers</span></div><p class=\"panel-description\">Select a row to edit it. Request type describes MoonGate's routing profile; it does not mean that app is connected.</p><div class=\"table-wrap\"><table><thead><tr><th>Provider</th><th>Request type</th><th>State</th><th>Action</th></tr></thead><tbody id=\"provider-rows\"></tbody></table></div></article><article class=\"panel wide\" id=\"provider-editor\"><div class=\"panel-head\"><div><p class=\"eyebrow\">Providers</p><h2>Provider Editor</h2></div><button type=\"button\" class=\"button-secondary\" id=\"provider-clear\">New Provider</button></div><div class=\"provider-route-banner\"><div><small>Selected routing profile</small><strong id=\"provider-active-route\">Loading provider route…</strong></div><button type=\"button\" class=\"button-secondary\" id=\"provider-use\" disabled>Use This Provider</button></div><form class=\"form-grid\" id=\"provider-form\"><input type=\"hidden\" autocomplete=\"off\" id=\"provider-original-id\"><input type=\"hidden\" autocomplete=\"off\" id=\"provider-original-app\"><div class=\"provider-template-picker span-2\"><label><span>Start from a template</span><select id=\"provider-template\"><option value=\"\">Choose a template</option></select></label><div class=\"inline-actions\"><button type=\"button\" class=\"button-secondary\" id=\"provider-template-apply\">Use Template</button><button type=\"button\" class=\"button-secondary\" id=\"provider-template-load\">Load JSON</button><button type=\"button\" class=\"button-secondary\" id=\"provider-template-reload\">Refresh Built-ins</button></div><input type=\"file\" autocomplete=\"off\" accept=\"application/json,.json\" id=\"provider-template-file\" hidden><small id=\"provider-template-status\">Templates fill the form; API keys are always entered separately.</small></div><label><span>Request type</span><select id=\"provider-app\"></select></label><label><span>Provider ID (internal name)</span><input type=\"text\" autocomplete=\"off\" placeholder=\"\" id=\"provider-id\" required></label><label><span>Name</span><input type=\"text\" autocomplete=\"off\" placeholder=\"\" id=\"provider-name\" required></label><label class=\"span-2\"><span>Base URL</span><input type=\"text\" autocomplete=\"off\" placeholder=\"https://api.example.com\" id=\"provider-base-url\"></label><label><span>API protocol</span><select id=\"provider-api-format\"><option value=\"\">Default</option><option value=\"openai\">OpenAI Responses</option><option value=\"openai_chat\">OpenAI Chat Completions</option><option value=\"anthropic\">Anthropic</option><option value=\"gemini_native\">Gemini Native</option></select></label><label><span>API Key</span><input type=\"password\" autocomplete=\"off\" id=\"provider-api-key\"></label><small class=\"field-hint\" id=\"provider-credential-status\">Enter the API key required by this provider.</small><label><span>Default Model</span><input type=\"text\" autocomplete=\"off\" placeholder=\"\" id=\"provider-default-model\"></label><label class=\"span-2\"><span>Notes</span><textarea rows=\"3\" id=\"provider-notes\"></textarea></label><details class=\"advanced-disclosure provider-advanced span-2\"><summary>Advanced provider options</summary><div class=\"provider-advanced-fields\"><label><span>Provider type</span><input type=\"text\" autocomplete=\"off\" placeholder=\"openrouter, codex_oauth, gemini\" id=\"provider-type\"></label><label><span>Sonnet model override</span><input type=\"text\" autocomplete=\"off\" placeholder=\"\" id=\"provider-sonnet-model\"></label><label><span>Haiku model override</span><input type=\"text\" autocomplete=\"off\" placeholder=\"\" id=\"provider-haiku-model\"></label><label><span>Opus model override</span><input type=\"text\" autocomplete=\"off\" placeholder=\"\" id=\"provider-opus-model\"></label><div class=\"check-row span-2\"><label><input type=\"checkbox\" autocomplete=\"off\" id=\"provider-full-url\"> Base URL is the complete request URL</label><label><input type=\"checkbox\" autocomplete=\"off\" id=\"provider-fast-mode\"> Faster Codex requests</label><label><input type=\"checkbox\" autocomplete=\"off\" id=\"provider-clear-models\"> Clear all model mappings</label></div></div></details><div class=\"check-row span-2\"><label><input type=\"checkbox\" autocomplete=\"off\" id=\"provider-enabled\" checked> Enabled</label><label><input type=\"checkbox\" autocomplete=\"off\" id=\"provider-clear-api-key\"> Remove stored API key</label></div><div class=\"form-actions span-2\"><button type=\"submit\" id=\"provider-save\">Save Provider</button><button type=\"button\" class=\"danger\" id=\"provider-delete\">Delete Provider</button><button type=\"button\" class=\"button-secondary\" id=\"provider-test\">Test Provider</button><span class=\"state\" id=\"provider-test-result\">Not tested</span><span id=\"provider-form-status\"></span></div></form></article></div></section><section data-page-view=\"requests\" data-page-title=\"Requests\" data-page-subtitle=\"See each AI request, which provider handled it, its cost, and whether it succeeded.\" class=\"page\" id=\"page-requests\"><div class=\"master-detail request-master-detail\"><article class=\"panel wide\" id=\"requests\"><div class=\"panel-head\"><div><p class=\"eyebrow\">Recent</p><h2>AI requests</h2></div><button data-copy-path=\"/usage/logs\" type=\"button\" class=\"button-secondary\">Copy Developer JSON URL</button></div><div data-i18n-scope=\"technical\" class=\"log-list\" id=\"request-log\"></div></article><article class=\"panel wide\" id=\"request-detail-panel\"><div class=\"panel-head\"><div><p class=\"eyebrow\">Request</p><h2>Request Detail</h2></div><span class=\"pill\" id=\"request-detail-id\">No selection</span></div><div data-i18n-scope=\"technical\" class=\"detail-grid\" id=\"request-detail\"></div></article></div></section><section data-page-view=\"usage\" data-page-title=\"Usage\" data-page-subtitle=\"Review requests, tokens, reused input, and estimated spend over time.\" class=\"page\" id=\"page-usage\"><article class=\"panel wide\" id=\"usage-explorer\"><div class=\"panel-head\"><div><p class=\"eyebrow\">Statistics</p><h2>Usage Explorer</h2></div><div class=\"filter-row\"><select aria-label=\"Usage framework\" id=\"usage-app\"></select><select aria-label=\"Usage range\" id=\"usage-range\"><option value=\"86400\">24 hours</option><option value=\"604800\" selected>7 days</option><option value=\"2592000\">30 days</option><option value=\"all\">All time</option></select><button type=\"button\" class=\"button-secondary\" id=\"usage-apply\">Apply</button></div></div><div class=\"usage-metrics\"><div><span>Requests</span><strong id=\"usage-filter-requests\">-</strong></div><div><span>Cost</span><strong id=\"usage-filter-cost\">-</strong></div><div><span>Tokens</span><strong id=\"usage-filter-tokens\">-</strong></div><div><span>Reused input</span><strong id=\"usage-filter-cache\">-</strong></div></div><div class=\"trend-bars\" id=\"usage-trends\"></div></article><div class=\"usage-breakdown-grid\"><article class=\"panel\" id=\"usage\"><div class=\"panel-head\"><div><p class=\"eyebrow\">Usage</p><h2>By App</h2></div></div><div class=\"stack\" id=\"app-usage\"></div></article><article class=\"panel\"><div class=\"panel-head\"><div><p class=\"eyebrow\">Providers</p><h2>By Provider</h2></div></div><div class=\"stack\" id=\"provider-usage\"></div></article><article class=\"panel\"><div class=\"panel-head\"><div><p class=\"eyebrow\">Models</p><h2>By Model</h2></div></div><div class=\"stack\" id=\"filtered-model-usage\"></div></article></div></section><section data-page-view=\"suite\" data-page-title=\"Moon Suite\" data-page-subtitle=\"See how MoonDesk and the other Moon apps connect to MoonGate. MoonDesk comes first.\" class=\"page\" id=\"page-suite\"><article class=\"panel wide\" id=\"suite\"><div class=\"panel-head\"><div><p class=\"eyebrow\">MoonDesk first</p><h2>Connected Moon apps</h2></div><div class=\"inline-actions\"><button type=\"button\" class=\"button-secondary\" id=\"suite-refresh\">Refresh Suite</button></div></div><p class=\"panel-description\">MoonDesk is the primary desktop control surface. The other Moon apps use MoonGate for AI routing, usage data, or health checks.</p><div class=\"usage-metrics\"><div><span>Connection</span><strong id=\"suite-status-state\">-</strong></div><div><span>Connected apps</span><strong id=\"suite-app-count\">-</strong></div><div><span>Shared features</span><strong id=\"suite-capability-count\">-</strong></div><div><span>MoonClaw Providers</span><strong id=\"suite-provider-count\">-</strong></div></div><div class=\"table-wrap\"><table><thead><tr><th>App</th><th>Purpose</th><th>What it uses MoonGate for</th><th>Connection check</th></tr></thead><tbody id=\"suite-app-rows\"></tbody></table></div><details class=\"advanced-disclosure suite-advanced\"><summary>Advanced suite files</summary><p>These actions refresh machine-readable files used by other Moon apps. Most users do not need them.</p><div class=\"advanced-actions\"><button type=\"button\" id=\"suite-write-status\">Rewrite Status File</button><button type=\"button\" class=\"button-secondary\" id=\"suite-write-moonclaw\">Rewrite MoonClaw Providers</button><code id=\"suite-status-path\">Loading status file…</code></div></details><div class=\"stack\" id=\"suite-integrations\"></div></article></section><section data-page-view=\"guide\" data-page-title=\"Guide\" data-page-subtitle=\"Learn what each page does and what MoonGate&#39;s technical phrases mean.\" class=\"page\" id=\"page-guide\"><div class=\"page-intro\"><div><h2>MoonGate in plain language</h2><p>MoonGate sits between your AI apps and AI providers. It gives the apps one local address, then sends each request to the provider you chose.</p></div></div><section class=\"guide-section\"><div class=\"section-title\"><h3>What each page is for</h3><span>Start here when you are unsure where to go</span></div><div class=\"guide-grid\"><article class=\"guide-card\"><h3>Overview</h3><p>Check whether MoonGate and AI routing are running, see the provider currently in use, and review request and spend totals.</p><button data-goto=\"overview\" type=\"button\" class=\"button-secondary\">Open Overview</button></article><article class=\"guide-card\"><h3>Connect</h3><p>Copy the local API address or command-line settings that another AI app asks you to enter.</p><button data-goto=\"connect\" type=\"button\" class=\"button-secondary\">Open Connect</button></article><article class=\"guide-card\"><h3>Setup</h3><p>Check signed-in accounts and whether installed AI apps such as Codex or Claude are ready to use MoonGate.</p><button data-goto=\"setup\" type=\"button\" class=\"button-secondary\">Open Setup</button></article><article class=\"guide-card\"><h3>Routing</h3><p>Choose which provider each AI app uses. Backup and failure settings are optional and live under Advanced.</p><button data-goto=\"routing\" type=\"button\" class=\"button-secondary\">Open Routing</button></article><article class=\"guide-card\"><h3>Providers</h3><p>Add or edit provider accounts, run a real connection test, and choose which provider is active.</p><button data-goto=\"providers\" type=\"button\" class=\"button-secondary\">Open Providers</button></article><article class=\"guide-card\"><h3>Requests</h3><p>Inspect individual AI calls, including their provider, model, result, token count, latency, and cost.</p><button data-goto=\"requests\" type=\"button\" class=\"button-secondary\">Open Requests</button></article><article class=\"guide-card\"><h3>Usage</h3><p>Review request, token, reused-input, and estimated-spend totals for a selected period.</p><button data-goto=\"usage\" type=\"button\" class=\"button-secondary\">Open Usage</button></article><article class=\"guide-card\"><h3>Suite</h3><p>See how MoonDesk, MoonClaw, MoonBook, and MoonTown connect to MoonGate. MoonDesk is the primary app.</p><button data-goto=\"suite\" type=\"button\" class=\"button-secondary\">Open Suite</button></article></div></section><section class=\"guide-section\"><div class=\"section-title\"><h3>Phrase guide</h3><span>The words you may see while configuring an AI app</span></div><div class=\"glossary-list\"><div class=\"glossary-item\"><strong>AI routing</strong><p>MoonGate receiving a request from an AI app and sending it to the provider you selected.</p></div><div class=\"glossary-item\"><strong>Provider</strong><p>An AI service or account that answers requests, such as Codex OAuth or Volcengine Ark.</p></div><div class=\"glossary-item\"><strong>Request type / routing profile</strong><p>The request format and provider group MoonGate will use, such as Codex Responses or Claude Messages. It does not prove that the named app is connected.</p></div><div class=\"glossary-item\"><strong>Selected route</strong><p>The provider MoonGate will use if a matching request arrives. Stop Using leaves that request type without a selected provider.</p></div><div class=\"glossary-item\"><strong>Model</strong><p>The specific AI model a provider should run, such as gpt-5.6-sol or kimi-k3.</p></div><div class=\"glossary-item\"><strong>API key</strong><p>A secret issued by a provider. MoonGate stores it locally and does not show the saved value again.</p></div><div class=\"glossary-item\"><strong>OAuth</strong><p>Signing in through an account instead of pasting an API key.</p></div><div class=\"glossary-item\"><strong>Base URL / API address</strong><p>The network address where an AI app sends requests. MoonGate's address normally starts with http://127.0.0.1.</p></div><div class=\"glossary-item\"><strong>API protocol</strong><p>The request format expected by a provider: OpenAI Responses, OpenAI Chat, Anthropic Messages, or Gemini Native.</p></div><div class=\"glossary-item\"><strong>Template</strong><p>A reusable provider setup that fills the non-secret fields for you. You still enter the API key separately.</p></div><div class=\"glossary-item\"><strong>Command-line apps (previously called tools)</strong><p>Installed programs such as Codex, Claude, Gemini, and OpenCode. MoonGate detects them only so it knows which apps it can configure.</p></div><div class=\"glossary-item\"><strong>AI tools</strong><p>Actions an AI model can call, such as reading a file or using a service. This is different from the installed command-line apps shown on Setup.</p></div><div class=\"glossary-item\"><strong>MCP</strong><p>Model Context Protocol. It lets an AI app connect to external capabilities such as files or services. You only need it when an app or plugin asks for MCP.</p></div><div class=\"glossary-item\"><strong>Backup provider / automatic backup</strong><p>Another provider MoonGate may try when the active provider fails.</p></div><div class=\"glossary-item\"><strong>Pause a failing provider (circuit breaker)</strong><p>An advanced safety rule that temporarily stops sending requests to a repeatedly failing provider.</p></div><div class=\"glossary-item\"><strong>Streaming</strong><p>Receiving an AI answer piece by piece instead of waiting for the whole response.</p></div><div class=\"glossary-item\"><strong>Tokens</strong><p>Small pieces of text counted by AI providers for limits and billing.</p></div><div class=\"glossary-item\"><strong>Reused input (cache hit)</strong><p>Input the provider could reuse instead of processing again; this may reduce time or cost.</p></div><div class=\"glossary-item\"><strong>Monitoring data / Prometheus metrics</strong><p>Machine-readable numbers for an external monitoring dashboard. It is not a MoonGate screen, so MoonGate only offers a Copy button for its URL.</p></div><div class=\"glossary-item\"><strong>Portable storage</strong><p>An advanced mode that keeps MoonGate data beside the app instead of in the normal user-data folder.</p></div></div></section></section><section class=\"error-box\" id=\"error-box\" hidden><strong>Data refresh failed</strong><p id=\"error-message\"></p></section></main></div><div aria-live=\"polite\" class=\"toast\" id=\"toast\"><span class=\"dot good\"></span><span id=\"toast-text\">Copied</span></div><script src=\"/assets/moonsuite-i18n.js\"></script><script src=\"/assets/moongate-core.js\"></script><script src=\"/assets/moongate-frameworks.js\"></script><script src=\"/assets/moongate-usage.js\"></script><script src=\"/assets/moongate-setup.js\"></script><script src=\"/assets/moongate-suite.js\"></script><script src=\"/assets/moongate-resilience.js\"></script><script src=\"/assets/moongate.js\"></script>",
  "runtime": {
    "backend": "system-webview",
    "assetProtocol": "lepusa",
    "devtools": false
  },
  "window": {
    "label": "main",
    "title": "MoonGate",
    "width": 1180,
    "height": 780,
    "resizable": true
  },
  "plugins": [
    {
      "name": "localhost"
    },
    {
      "name": "serviceDiscovery"
    },
    {
      "name": "opener"
    }
  ],
  "capabilities": [
    {
      "name": "main",
      "windows": [
        "main"
      ],
      "permissions": [
        "localhost",
        "service-discovery",
        "opener"
      ]
    }
  ],
  "startup": {
    "effect": "connect-moongate-rabbita-preview"
  }
}

{
  "identifier": "dev.vectie.moonstat.rabbita",
  "productName": "Moonstat Rabbita Preview",
  "version": "0.1.0",
  "rootHtml": "<div data-moonstat-api-base=\"http://127.0.0.1:15721\" class=\"shell\"><aside class=\"sidebar\"><div class=\"brand\"><span class=\"mark\">M</span><div><strong>Moonstat</strong><span>Lepusa Rabbita shell</span></div></div><nav class=\"nav\"><a href=\"#overview\" target=\"_self\">Overview</a><a href=\"#providers\" target=\"_self\">Providers</a><a href=\"#frameworks\" target=\"_self\">Frameworks</a><a href=\"#suite\" target=\"_self\">Suite</a><a href=\"#usage\" target=\"_self\">Usage</a></nav></aside><main class=\"main\"><section class=\"topbar\" id=\"overview\"><div><p class=\"eyebrow\">Operator Console</p><h1>Proxy, providers, and spend in one place.</h1></div><div class=\"actions\"><button type=\"button\" id=\"refresh\">Refresh</button><button type=\"button\" id=\"proxy-start\">Start Proxy</button><button type=\"button\" class=\"danger\" id=\"proxy-stop\">Stop Proxy</button></div></section><section class=\"status-grid\"><article class=\"metric-card\"><span>Gateway</span><strong id=\"gateway-state\">-</strong><small id=\"gateway-detail\">Waiting for data</small></article><article class=\"metric-card\"><span>Proxy</span><strong id=\"proxy-state\">-</strong><small id=\"proxy-detail\">Waiting for data</small></article><article class=\"metric-card\"><span>Requests</span><strong id=\"request-total\">-</strong><small id=\"request-total-detail\">Waiting for data</small></article><article class=\"metric-card\"><span>Spend</span><strong id=\"cost-total\">-</strong><small id=\"cost-detail\">Waiting for data</small></article></section><section class=\"panel-grid\"><article class=\"panel wide\" id=\"frameworks\"><div class=\"panel-head\"><div><p class=\"eyebrow\">Frameworks</p><h2>Provider Control</h2></div></div><div class=\"stack\" id=\"framework-rows\"><div class=\"row-card\"><strong>No data yet</strong><small>Moonstat will populate this panel from the local gateway.</small></div></div></article><article class=\"panel wide\" id=\"providers\"><div class=\"panel-head\"><div><p class=\"eyebrow\">Routing</p><h2>Provider Health</h2></div></div><div class=\"stack\" id=\"provider-rows\"><div class=\"row-card\"><strong>No data yet</strong><small>Moonstat will populate this panel from the local gateway.</small></div></div></article><article class=\"panel wide\" id=\"suite\"><div class=\"panel-head\"><div><p class=\"eyebrow\">Suite</p><h2>Moon Suite Integration</h2></div></div><div class=\"stack\" id=\"suite-app-rows\"><div class=\"row-card\"><strong>No data yet</strong><small>Moonstat will populate this panel from the local gateway.</small></div></div></article><article class=\"panel wide\" id=\"usage\"><div class=\"panel-head\"><div><p class=\"eyebrow\">Usage</p><h2>Usage Explorer</h2></div></div><div class=\"stack\" id=\"app-usage\"><div class=\"row-card\"><strong>No data yet</strong><small>Moonstat will populate this panel from the local gateway.</small></div></div></article></section></main></div>",
  "runtime": {
    "backend": "system-webview",
    "assetProtocol": "lepusa",
    "devtools": false
  },
  "window": {
    "label": "main",
    "title": "Moonstat",
    "width": 1180,
    "height": 780,
    "resizable": true
  },
  "plugins": [
    { "name": "localhost" },
    { "name": "serviceDiscovery" },
    { "name": "opener" }
  ],
  "capabilities": [
    {
      "name": "main",
      "windows": ["main"],
      "permissions": ["localhost", "service-discovery", "opener"]
    }
  ],
  "startup": { "effect": "connect-moonstat-rabbita-preview" }
}
